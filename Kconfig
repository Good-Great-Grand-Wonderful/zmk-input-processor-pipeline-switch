DT_COMPAT_ZMK_INPUT_PROCESSOR_PIPELINE_SWITCH := zmk,input-processor-pipeline-switch
DT_COMPAT_ZMK_BEHAVIOR_PIPELINE_SWITCH := zmk,behavior-pipeline-switch

config ZMK_INPUT_PROCESSOR_PIPELINE_SWITCH
	bool
	default $(dt_compat_enabled,$(DT_COMPAT_ZMK_INPUT_PROCESSOR_PIPELINE_SWITCH))
	imply SETTINGS

config ZMK_BEHAVIOR_PIPELINE_SWITCH
	bool
	default $(dt_compat_enabled,$(DT_COMPAT_ZMK_BEHAVIOR_PIPELINE_SWITCH))
	depends on ZMK_INPUT_PROCESSOR_PIPELINE_SWITCH
